    {
      "name": "Reservations (Customer)  [mostly Phase 2]",
      "description": "Customer login + role are implemented; reservation CRUD is PLANNED (Phase 2, not yet in backend).",
      "item": [
        {
          "name": "Customer: OTP Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data.devCode) pm.environment.set('otpCode', res.data.devCode);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{customerPhone}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/otp/request", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "request"] },
            "description": "Request OTP for the customer's phone."
          }
        },
        {
          "name": "Customer: OTP Verify",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data.tokens) {",
                  "  pm.environment.set('accessToken', res.data.tokens.accessToken);",
                  "  pm.environment.set('refreshToken', res.data.tokens.refreshToken);",
                  "}",
                  "if (res && res.data && res.data.user) pm.environment.set('customerId', res.data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{customerPhone}}\",\n  \"code\": \"{{otpCode}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/otp/verify", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "verify"] },
            "description": "Log in as the customer. Saves tokens + customerId."
          }
        },
