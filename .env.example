# Server
PORT=4000
BASE_URL=http://localhost:4000
# Public URL of the frontend (used to build salon invite links).
WEB_BASE_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/salon_reservation

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
ACCESS_TTL=1500m
REFRESH_TTL=7d

# OTP (seconds the OTP stays valid)
OTP_TTL=300

# Storage
UPLOAD_DIR=uploads

# Environment (development | production)
NODE_ENV=development

# Scheduled jobs
# Set DISABLE_CRON=true to turn off all background jobs (tests, one-off scripts).
DISABLE_CRON=false
# How often the reservation auto-complete job runs (minutes).
AUTOCOMPLETE_INTERVAL_MINUTES=5
# Optional shared secret to call /internal/* endpoints (required in production).
INTERNAL_API_KEY=

# Bootstrap admin phone (used by `npm run seed:admin`). Stored as 09xxxxxxxxx —
# the same format the OTP/registration flow uses.
ADMIN_PHONE=09369921986

# Private storage root for sensitive files (ID documents). MUST stay outside
# UPLOAD_DIR so it is never served by the public /uploads mount.
PRIVATE_UPLOAD_DIR=uploads-private
