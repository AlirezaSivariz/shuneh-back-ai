# Server
PORT=4000
BASE_URL=http://localhost:4000
# Public URL of the frontend (used to build salon invite links).
WEB_BASE_URL=http://localhost:3000

# Database — set MONGODB_URI to your own MongoDB Atlas connection string.
# IMPORTANT: include an explicit database name before the "?" (e.g. /shooneh)
# so data is NOT written to the default `test` database. Never commit real creds.
MONGODB_URI=mongodb+srv://USER:PASSWORD@your-cluster.mongodb.net/shooneh?retryWrites=true&w=majority
# Local fallback (used only when MONGODB_URI is unset):
# MONGO_URI=mongodb://127.0.0.1:27017/salon_reservation

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
ACCESS_TTL=1500m
REFRESH_TTL=7d

# OTP (seconds the OTP stays valid)
OTP_TTL=300

# SMS gateway: stub (console log, dev fixed code) | limosms (real). With limosms:
#  - OTP is generated AND verified by LimoSMS itself (sendcode/checkcode); we
#    store no code on our side and NO fixed dev code works.
#  - Notification SMS (new reservation, reschedule, salon approval, invite link…)
#    are sent via LimoSMS `sendsms` using LIMOSMS_SENDER_NUMBER below.
SMS_DRIVER=limosms
# LimoSMS API key (required when SMS_DRIVER=limosms). Read only from env, never
# hardcoded. Put your real key in .env (which is git-ignored), not here.
# LIMOSMS_API_KEY=efa152a3-9be5-4bcb-bd4e-b4f54c323267
LIMOSMS_API_KEY=
LIMOSMS_FOOTER=شونه
# LimoSMS sender for notification SMS (sendsms). Per LimoSMS support this is the
# literal string "vip" (not a line number). Sent as a string; change only if
# LimoSMS later requires a different value.
LIMOSMS_SENDER_NUMBER=vip

# Storage driver: local (disk) | mongo (BinData, temporary test-phase) | s3 (MinIO/S3)
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
# Required when STORAGE_DRIVER=s3. MinIO usually needs S3_FORCE_PATH_STYLE=true.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BUCKET=shuneh-public
S3_PRIVATE_BUCKET=shuneh-private
S3_FORCE_PATH_STYLE=true

# Environment (development | production)
NODE_ENV=development

# Scheduled jobs
# Set DISABLE_CRON=true to turn off all background jobs (tests, one-off scripts).
DISABLE_CRON=false
# How often the reservation auto-complete job runs (minutes).
AUTOCOMPLETE_INTERVAL_MINUTES=5
# Optional shared secret to call /internal/* endpoints (required in production).
INTERNAL_API_KEY=

# Bootstrap admin phone (used by `npm run seed:admin`). The admin logs in with
# the normal OTP flow like everyone else. Stored as 09xxxxxxxxx.
ADMIN_PHONE=09369921986

# Private storage root for sensitive files (ID documents). MUST stay outside
# UPLOAD_DIR so it is never served by the public /uploads mount.
PRIVATE_UPLOAD_DIR=uploads-private
